<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Room List</title>
</head>
<body>
    <h1>Admin Room List</h1>
    <!-- 객실 리스트를 테이블로 출력 -->
    <table border="1">
        <thead>
            <tr>
                <th>Room Number</th>
                <th>Floor</th>
                <th>Status</th>
                <th>View</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            <!-- Thymeleaf를 사용하여 'rooms' 모델에 전달된 데이터를 반복하여 출력 -->
            <tr th:each="room : ${rooms}">
                <td th:text="${room.roomNumber}">Room Number</td> <!-- 객실 번호 -->
                <td th:text="${room.floor}">Floor</td> <!-- 층 -->
                <td th:text="${room.status}">Status</td> <!-- 상태 -->
                <td th:text="${room.view}">View</td> <!-- 뷰 -->
                <td th:text="${room.createdAt}">Created At</td> <!-- 생성일 -->
            </tr>
        </tbody>
    </table>
</body>
</html>

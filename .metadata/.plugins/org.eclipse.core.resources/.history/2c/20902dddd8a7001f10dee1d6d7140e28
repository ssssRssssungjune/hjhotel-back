<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hjhotelback.mapper.room.RoomRepository">
    <!-- 24.11.21 진주 : 객실 리스트 조회 ( 사용자 ) -->
    <select id="AllRooms" resultType="com.hjhotelback.dto.room.RoomDto_Client">
        SELECT * FROM room ORDER BY room_number ASC;
    </select>
    
    <!-- 24.11.21 진주 : 객실 리스트 조회 ( 관리자 ) -->
     <select id="AllAdminRooms" resultType="com.hjhotelback.dto.room.RoomDto">
           SELECT * FROM room ORDER BY room_type_id ASC , room_number ASC;
    </select>
    
     <!-- 24.11.21 진주 : 전체 객실 상태 조회 ( 관리자 ) -->
     <select id="AllStatus" resultType="com.hjhotelback.dto.room.RoomDto">
           SELECT * FROM room ORDER BY room_type_id ASC , room_number ASC;
    </select>
    
</mapper>
package com.hjhotelback.controller.room;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.hjhotelback.dto.room.RoomDto;
import com.hjhotelback.dto.room.RoomDto_Client;
import com.hjhotelback.service.room.RoomService;

@RestController
public class RoomController {
	@Autowired
	private RoomService roomService;
	
	// 24.11.21 진주 : 사용자페이지 리스트 불러오기
	@GetMapping("/api/rooms")
	public List<RoomDto_Client> getRooms(){
		return roomService.getRooms();	}
	
	// 24.11.21 진주 : 관리자페이지 리스트 불러오기
	
	@GetMapping("/api/admin/rooms")
	public List<RoomDto> getAdminRooms(){
		return roomService.getAdminRooms();	}
	
	@GetMapping("/api/admin/rooms/{status}")
	public List<RoomDto> getStatus(@PathVariable String status){
		return roomService.getStatus(status);
	}
	
	
	
}
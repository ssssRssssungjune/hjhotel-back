<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전체 객실 리스트</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <header>
        <h1>전체 객실 리스트</h1>
    </header>

    <main>
        <!-- 전체 객실 리스트 테이블 -->
        <table id="roomTable">
            <thead>
                <tr>
                    <th>객실 번호</th>
                    <th>객실 타입 ID</th>
                    <th>층</th>
                    <th>생성 일자</th>
                    <th>상태</th>
                    <th>뷰</th>
                </tr>
            </thead>
            <tbody>
                <!-- 객실 데이터가 여기에 동적으로 채워집니다. -->
            </tbody>
        </table>
    </main>

    <script>
        // 페이지 로드 시 모든 객실 리스트를 불러옴
        document.addEventListener('DOMContentLoaded', function() {
            fetchAdminRooms();  // 모든 객실 조회 API 호출
        });

        // 모든 객실 조회 함수
        function fetchAdminRooms() {
            const apiUrl = '/api/admin/rooms';  // 관리자 페이지의 모든 객실 조회 API URL

            // 테이블을 비워서 새로운 데이터를 삽입
            const roomTableBody = document.querySelector('#roomTable tbody');
            roomTableBody.innerHTML = '';  // 기존 테이블 내용 비우기

            fetch(apiUrl)
                .then(response => response.json())
                .then(data => {
                    // 데이터가 없으면 알림 메시지 표시
                    if (data.length === 0) {
                        const row = document.createElement('tr');
                        row.innerHTML = `<td colspan="6">등록된 객실이 없습니다.</td>`;
                        roomTableBody.appendChild(row);
                        return;
                    }

                    // 데이터를 테이블에 추가
                    data.forEach(room => {
                        const row = document.createElement('tr');
                        row.innerHTML = `
                            <td>${room.roomNumber}</td>
                            <td>${room.roomTypeId}</td>
                            <td>${room.floor}</td>
                            <td>${new Date(room.createdAt).toLocaleDateString()}</td>
                            <td>${room.status}</td>
                            <td>${room.view}</td>
                        `;
                        roomTableBody.appendChild(row);
                    });
                })
                .catch(error => {
                    console.error('객실 리스트를 불러오는 데 실패했습니다:', error);
                });
        }
    </script>

</body>
</html>